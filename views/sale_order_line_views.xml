<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="sale_order_form_view" model="ir.ui.view">
        <field name="name">sale.order.line.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='price_subtotal']" position="before">
                <field name="milestone"/>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_create_so_project"
                        type="object"
                        string="Create Project"
                        class="btn-primary"
                        invisible="state != 'sale' or created == True"
                />
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_update_so_project"
                        type="object"
                        string="Update Project"
                        class="btn-primary"
                        invisible="state != 'sale' or created == False"
                />
            </xpath>
        </field>
    </record>
</odoo>